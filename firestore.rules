rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        request.auth.uid in [
          "kgb0KhPYWLZYXt5YdAA7iuHMxYT2",
          "rkT0L6EK6Yd2IFNHBIQ8dVgqdHX2",
          "KhK0yllx62f20RU6YkUbxcDC3W53"
        ];
    }

    match /notices/{documentId} {
      allow read: if isAdmin() || resource.data.visible == true;
      allow create, update, delete: if isAdmin();
    }

    match /scheduleEvents/{documentId} {
      allow read: if isAdmin() || resource.data.visible == true;
      allow create, update, delete: if isAdmin();
    }

    match /videos/{documentId} {
      allow read: if isAdmin() || resource.data.visible == true;
      allow create, update, delete: if isAdmin();
    }

    match /siteSettings/{documentId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
